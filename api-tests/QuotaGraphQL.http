### 5. reserveQuota — reserve data (OCTETS) from a subscriber's quota
POST {{baseUrl}}/api/charging/graphql
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "query": "mutation ReserveQuota($reservationId: ID!, $subscriberId: ID!, $reasonCode: ReasonCode!, $rateKey: QuotaRateKeyInput!, $unitType: UnitType!, $requestedUnits: Int!, $unitPrice: String!, $validitySeconds: Int!, $allowOOBCharging: Boolean!) { reserveQuota(reservationId: $reservationId, subscriberId: $subscriberId, reasonCode: $reasonCode, rateKey: $rateKey, unitType: $unitType, requestedUnits: $requestedUnits, unitPrice: $unitPrice, validitySeconds: $validitySeconds, allowOOBCharging: $allowOOBCharging) { grantedUnits } }",
  "variables": {
    "reservationId": "11111111-1111-1111-1111-111111111111",
    "subscriberId": "cb2fec7d-1035-40f1-8d62-d3fbddfb6dc2",
    "reasonCode": "SERVICE_USAGE",
    "rateKey": {
      "serviceType": "DATA",
      "sourceType": "HOME",
      "serviceDirection": "MO",
      "serviceCategory": "INTERNET",
      "serviceWindow": "PEAK"
    },
    "unitType": "OCTETS",
    "requestedUnits": 1048576,
    "unitPrice": "0.25",
    "validitySeconds": 3600,
    "allowOOBCharging": false
  }
}

### 6. debitQuota — debit previously reserved units
POST {{baseUrl}}/api/charging/graphql
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "query": "mutation DebitQuota($subscriberId: ID!, $reservationId: ID!, $usedUnits: Int!, $unitType: UnitType!, $reclaimUnusedUnits: Boolean!) { debitQuota(subscriberId: $subscriberId, reservationId: $reservationId, usedUnits: $usedUnits, unitType: $unitType, reclaimUnusedUnits: $reclaimUnusedUnits) { unitsDebited unitsValue valueUnits unaccountedUnits } }",
  "variables": {
    "subscriberId": "cb2fec7d-1035-40f1-8d62-d3fbddfb6dc2",
    "reservationId": "11111111-1111-1111-1111-111111111111",
    "usedUnits": 524288,
    "unitType": "OCTETS",
    "reclaimUnusedUnits": true
  }
}

### 7. cancelQuotaReservations — cancel all reservations for a reservation ID
POST {{baseUrl}}/api/charging/graphql
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "query": "mutation CancelQuotaReservations($reservationId: ID!, $subscriberId: ID!) { cancelQuotaReservations(reservationId: $reservationId, subscriberId: $subscriberId) { success } }",
  "variables": {
    "reservationId": "11111111-1111-1111-1111-111111111111",
    "subscriberId": "cb2fec7d-1035-40f1-8d62-d3fbddfb6dc2"
  }
}
